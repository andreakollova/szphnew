{
  "name": "szph-monorepo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "dev:fieldhockey": "turbo run dev --filter=fieldhockey",
    "dev:szph": "turbo run dev --filter=szph",
    "build:fieldhockey": "turbo run build --filter=fieldhockey",
    "build:szph": "turbo run build --filter=szph"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
